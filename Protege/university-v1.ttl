@prefix : <http://www.semanticweb.org/jingzhao/ontologies/2026/6/untitled-ontology-7/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/jingzhao/ontologies/2026/6/untitled-ontology-7/> .

<http://www.example.org/university#> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/university#teaches
:teaches rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Teacher ;
         rdfs:range :Student .


#################################################################
#    Data properties
#################################################################

###  http://www.example.org/university#hasAge
:hasAge rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdfs:range xsd:int .


###  http://www.example.org/university#hasName
:hasName rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://www.example.org/university#Person
:Person rdf:type owl:Class .


###  http://www.example.org/university#Student
:Student rdf:type owl:Class ;
         rdfs:subClassOf :Person .


###  http://www.example.org/university#Teacher
:Teacher rdf:type owl:Class ;
         rdfs:subClassOf :Person .


#################################################################
#    Individuals
#################################################################

###  http://www.example.org/university#Alice
:Alice rdf:type owl:NamedIndividual ,
                :Teacher ;
       :teaches :Bob ;
       :hasAge 35 ;
       :hasName "Alice" .


###  http://www.example.org/university#Bob
:Bob rdf:type owl:NamedIndividual ,
              :Student ;
     :hasAge 20 ;
     :hasName "Bob" .


