<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/jingzhao/ontologies/2026/6/untitled-ontology-7/"
     xml:base="http://www.semanticweb.org/jingzhao/ontologies/2026/6/untitled-ontology-7/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:university="http://www.example.org/university#">
    <owl:Ontology rdf:about="http://www.example.org/university#"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.example.org/university#teaches -->

    <owl:ObjectProperty rdf:about="http://www.example.org/university#teaches">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/university#Teacher"/>
        <rdfs:range rdf:resource="http://www.example.org/university#Student"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.example.org/university#hasAge -->

    <owl:DatatypeProperty rdf:about="http://www.example.org/university#hasAge">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/university#hasName -->

    <owl:DatatypeProperty rdf:about="http://www.example.org/university#hasName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.example.org/university#Person -->

    <owl:Class rdf:about="http://www.example.org/university#Person"/>
    


    <!-- http://www.example.org/university#Student -->

    <owl:Class rdf:about="http://www.example.org/university#Student">
        <rdfs:subClassOf rdf:resource="http://www.example.org/university#Person"/>
    </owl:Class>
    


    <!-- http://www.example.org/university#Teacher -->

    <owl:Class rdf:about="http://www.example.org/university#Teacher">
        <rdfs:subClassOf rdf:resource="http://www.example.org/university#Person"/>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.example.org/university#Alice -->

    <owl:NamedIndividual rdf:about="http://www.example.org/university#Alice">
        <rdf:type rdf:resource="http://www.example.org/university#Teacher"/>
        <university:teaches rdf:resource="http://www.example.org/university#Bob"/>
        <university:hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">35</university:hasAge>
        <university:hasName>Alice</university:hasName>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/university#Bob -->

    <owl:NamedIndividual rdf:about="http://www.example.org/university#Bob">
        <rdf:type rdf:resource="http://www.example.org/university#Student"/>
        <university:hasAge rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">20</university:hasAge>
        <university:hasName>Bob</university:hasName>
    </owl:NamedIndividual>
</rdf:RDF>



